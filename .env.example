# Oxlo.ai API Configuration
OXLO_API_KEY=your_oxlo_api_key
OXLO_BASE_URL=https://api.oxlo.ai/v1

# Preferred Free / Default Models
# Text queries (e.g., general Q&A, explanations)
OXLO_TEXT_MODEL=llama-3.2-3b

# Coding queries
OXLO_CODE_MODEL=deepseek-coder-33b

# Embedding model for RAG (Documents)
OXLO_EMBEDDING_MODEL=bge-large

# Image generation model
OXLO_IMAGE_MODEL=stable-diffusion-1.5
